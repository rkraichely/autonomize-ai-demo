# Anthropic (always required)
ANTHROPIC_API_KEY=sk-ant-...

# Model selection — swap to claude-opus-4-7 for stronger tool-use reasoning
MODEL=claude-sonnet-4-6

# Set to true to skip JIRA/GitHub and use built-in mock team data
USE_MOCK_DATA=false

# JIRA (not needed when USE_MOCK_DATA=true)
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=...

# GitHub (not needed when USE_MOCK_DATA=true)
GITHUB_TOKEN=ghp_...
